        "textMode": "auto"
      },
      "pluginVersion": "9.3.6",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({unit=~\"$unit\"}[$__interval]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Total Log Count",
      "type": "stat"
    },
