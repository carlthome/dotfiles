        "uid": "${DS_LOKI}"
      },
      "description": "Total count of log lines in the specified time range",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "match": "null",
                "result": {
                  "color": "rgb(31, 255, 7)",
                  "text": "0"
                }
              },
              "type": "special"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "rgb(31, 255, 7)",
                "value": null
              },
              {
                "color": "rgb(31, 255, 7)",
                "value": 10
              },
              {
                "color": "rgb(31, 255, 7)",
                "value": 50
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
